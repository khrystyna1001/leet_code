class Solution:
    def uniquePaths(self, m: int, n: int) -> int:
        row = [1] * n
    
        # Iterate through the grid (starting from the second row)
        for i in range(m - 1):
            for j in range(1, n):
                # The new value is the old value (above) + the value to the left
                row[j] += row[j - 1]

        return row[-1]
